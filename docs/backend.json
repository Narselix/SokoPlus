
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Represents a user's profile in the system.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "The user's full name."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email address."
        },
        "role": {
          "type": "string",
          "description": "The user's role in the application.",
          "enum": [
            "Student",
            "Teacher",
            "Admin",
            "Parent"
          ]
        }
      },
      "required": ["name", "email", "role"]
    },
    "SchoolFee": {
      "title": "School Fee",
      "description": "Represents a school fee payment record.",
      "type": "object",
      "properties": {
        "studentId": { "type": "string" },
        "amount": { "type": "string" },
        "status": { "type": "string", "enum": ["Payé", "En attente", "Partiel"] },
        "date": { "type": "string", "format": "date-time" },
        "term": { "type": "string" }
      },
      "required": ["studentId", "amount", "status"]
    },
    "StudentGrade": {
      "title": "Student Grade",
      "description": "Represents a grade obtained by a student.",
      "type": "object",
      "properties": {
        "studentId": { "type": "string" },
        "subject": { "type": "string" },
        "score": { "type": "number" },
        "maxScore": { "type": "number" },
        "term": { "type": "string" },
        "date": { "type": "string", "format": "date-time" }
      },
      "required": ["studentId", "subject", "score"]
    },
    "Attendance": {
      "title": "Attendance",
      "description": "Represents an attendance record.",
      "type": "object",
      "properties": {
        "studentId": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "status": { "type": "string", "enum": ["Présent", "Absent", "Retard"] }
      },
      "required": ["studentId", "date", "status"]
    },
    "SchoolNews": {
      "title": "School News",
      "description": "General news and announcements from the school.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "category": { "type": "string" }
      },
      "required": ["title", "content", "date"]
    },
    "Product": {
      "title": "Product",
      "description": "Represents a product listed on the marketplace.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "string" },
        "category": { "type": "string" },
        "location": { "type": "string" },
        "sellerId": { "type": "string" },
        "imageUrls": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["name", "price", "category", "sellerId"]
    },
    "Housing": {
      "title": "Housing",
      "description": "Represents a housing property listed on the platform.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "string" },
        "type": { "type": "string", "enum": ["Maison", "Chambre", "Studio", "Terrain"] },
        "location": { "type": "string" },
        "ownerId": { "type": "string" },
        "imageUrls": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["title", "price", "type", "location", "ownerId"]
    }
  },
  "auth": {
    "providers": ["email_password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/UserProfile" },
      "description": "Stores user profile information."
    },
    "/schoolFees/{feeId}": {
      "schema": { "$ref": "#/entities/SchoolFee" },
      "description": "Stores school fee records."
    },
    "/grades/{gradeId}": {
      "schema": { "$ref": "#/entities/StudentGrade" },
      "description": "Stores student grades."
    },
    "/attendance/{attendanceId}": {
      "schema": { "$ref": "#/entities/Attendance" },
      "description": "Stores attendance records."
    },
    "/schoolNews/{newsId}": {
      "schema": { "$ref": "#/entities/SchoolNews" },
      "description": "Stores school announcements."
    }
  }
}
