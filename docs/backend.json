
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Represents a user's profile in the system.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": {
          "type": "string",
          "enum": ["Student", "Parent", "Teacher", "Accountant", "SchoolAdmin", "SuperAdmin"]
        },
        "schoolId": { "type": "string", "description": "ID of the school the user belongs to" }
      },
      "required": ["name", "email", "role"]
    },
    "School": {
      "title": "School",
      "description": "Educational institution registered on Soko+",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "logoUrl": { "type": "string" },
        "stampUrl": { "type": "string", "description": "Official stamp image" },
        "address": { "type": "string" },
        "city": { "type": "string" },
        "province": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "directorName": { "type": "string" },
        "currency": { "type": "string", "enum": ["USD", "CDF"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "city", "province", "currency"]
    },
    "Student": {
      "title": "Student",
      "description": "Student registered in a school",
      "type": "object",
      "properties": {
        "schoolId": { "type": "string" },
        "matricule": { "type": "string" },
        "name": { "type": "string" },
        "firstName": { "type": "string" },
        "gender": { "type": "string", "enum": ["M", "F"] },
        "birthDate": { "type": "string", "format": "date" },
        "classId": { "type": "string" },
        "parentName": { "type": "string" },
        "parentPhone": { "type": "string" },
        "address": { "type": "string" }
      },
      "required": ["schoolId", "matricule", "name", "firstName", "classId"]
    },
    "FeeConfig": {
      "title": "Fee Configuration",
      "description": "Types of fees defined by the school",
      "type": "object",
      "properties": {
        "schoolId": { "type": "string" },
        "name": { "type": "string" },
        "amount": { "type": "number" },
        "description": { "type": "string" }
      }
    },
    "Payment": {
      "title": "Payment",
      "description": "Record of a student fee payment",
      "type": "object",
      "properties": {
        "schoolId": { "type": "string" },
        "studentId": { "type": "string" },
        "feeId": { "type": "string" },
        "amount": { "type": "number" },
        "method": { "type": "string", "enum": ["Cash", "Mobile Money", "Bank"] },
        "date": { "type": "string", "format": "date-time" },
        "receiptNumber": { "type": "string" },
        "comptableId": { "type": "string" }
      }
    }
  },
  "firestore": {
    "/schools/{schoolId}": { "schema": { "$ref": "#/entities/School" } },
    "/students/{studentId}": { "schema": { "$ref": "#/entities/Student" } },
    "/feeConfigs/{feeId}": { "schema": { "$ref": "#/entities/FeeConfig" } },
    "/payments/{paymentId}": { "schema": { "$ref": "#/entities/Payment" } }
  }
}
