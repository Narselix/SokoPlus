{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Represents a user's profile in the system.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "The user's full name."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email address."
        },
        "role": {
          "type": "string",
          "description": "The user's role in the application.",
          "enum": [
            "Student",
            "Teacher",
            "Admin"
          ]
        }
      },
      "required": ["name", "email", "role"]
    },
    "Product": {
      "title": "Product",
      "description": "Represents a product listed on the marketplace.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "The name of the product."
        },
        "description": {
          "type": "string",
          "description": "A detailed description of the product."
        },
        "price": {
          "type": "number",
          "description": "The price of the product."
        },
        "category": {
          "type": "string",
          "description": "The category the product belongs to."
        },
        "location": {
          "type": "string",
          "description": "The location of the seller."
        },
        "sellerId": {
          "type": "string",
          "description": "The ID of the user selling the product."
        },
        "imageUrl": {
          "type": "string",
          "description": "The URL of the product image."
        }
      },
      "required": [
        "name",
        "price",
        "category",
        "sellerId"
      ]
    },
    "Order": {
      "title": "Order",
      "description": "Represents an order placed by a user for a product.",
      "type": "object",
      "properties": {
        "productId": {
          "type": "string"
        },
        "buyerId": {
          "type": "string"
        },
        "sellerId": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": [
            "placed",
            "confirmed",
            "shipped",
            "delivered",
            "cancelled"
          ]
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "productId",
        "buyerId",
        "sellerId",
        "status"
      ]
    },
    "Housing": {
      "title": "Housing",
      "description": "Represents a housing property listed on the platform.",
      "type": "object",
      "properties": {
        "title": {
          "type": "string",
          "description": "The title of the housing listing."
        },
        "description": {
          "type": "string",
          "description": "A detailed description of the property."
        },
        "price": {
          "type": "string",
          "description": "The price of the housing (e.g., per month)."
        },
        "type": {
            "type": "string",
            "description": "Type of housing.",
            "enum": ["Maison", "Chambre", "Studio", "Terrain"]
        },
        "location": {
          "type": "string",
          "description": "The location of the property."
        },
        "ownerId": {
          "type": "string",
          "description": "The ID of the user listing the property."
        },
        "imageUrls": {
          "type": "array",
          "items": {
              "type": "string"
          },
          "description": "URLs of the property images."
        }
      },
      "required": [
        "title",
        "price",
        "type",
        "location",
        "ownerId"
      ]
    },
    "Transport": {
      "title": "Transport",
      "description": "Represents a transport service offered on the platform.",
      "type": "object",
      "properties": {
        "driverId": {
          "type": "string",
          "description": "The ID of the user offering the service."
        },
        "driverName": {
            "type": "string",
            "description": "The name of the driver."
        },
        "type": {
            "type": "string",
            "description": "Type of transport.",
            "enum": ["Taxi Moto", "Taxi Voiture", "Collectif", "Marchandises"]
        },
        "vehicle": {
            "type": "string",
            "description": "Information about the vehicle (e.g., make, model, license plate)."
        },
        "location": {
          "type": "string",
          "description": "The driver's current or base location."
        },
        "rating": {
            "type": "number",
            "description": "The driver's average rating."
        },
        "imageUrl": {
          "type": "string",
          "description": "The URL of the vehicle/driver image."
        }
      },
      "required": [
        "driverId",
        "driverName",
        "type",
        "vehicle",
        "location"
      ]
    }
  },
  "auth": {
    "providers": [
      "email_password"
    ]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": {
        "$ref": "#/entities/UserProfile"
      },
      "description": "Stores user profile information."
    },
    "/products/{productId}": {
      "schema": {
        "$ref": "#/entities/Product"
      },
      "description": "Stores product listings for the marketplace."
    },
    "/orders/{orderId}": {
      "schema": {
        "$ref": "#/entities/Order"
      },
      "description": "Stores user orders for marketplace products."
    },
    "/housing/{housingId}": {
      "schema": {
        "$ref": "#/entities/Housing"
      },
      "description": "Stores housing listings."
    },
    "/transport/{transportId}": {
      "schema": {
        "$ref": "#/entities/Transport"
      },
      "description": "Stores transport service listings."
    }
  }
}
