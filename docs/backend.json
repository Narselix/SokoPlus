
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Represents a user's profile in the system.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": {
          "type": "string",
          "enum": ["Student", "Parent", "Teacher", "Accountant", "SchoolAdmin", "SuperAdmin"]
        },
        "schoolId": { "type": "string", "description": "ID of the school the user belongs to" }
      },
      "required": ["name", "email", "role"]
    },
    "School": {
      "title": "School",
      "description": "Educational institution registered on Soko+",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "logoUrl": { "type": "string" },
        "stampUrl": { "type": "string", "description": "Official stamp image" },
        "address": { "type": "string" },
        "city": { "type": "string" },
        "province": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "directorName": { "type": "string" },
        "currency": { "type": "string", "enum": ["USD", "CDF"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "city", "province", "currency"]
    },
    "Student": {
      "title": "Student",
      "description": "Student registered in a school",
      "type": "object",
      "properties": {
        "schoolId": { "type": "string" },
        "matricule": { "type": "string" },
        "name": { "type": "string" },
        "firstName": { "type": "string" },
        "gender": { "type": "string", "enum": ["M", "F"] },
        "birthDate": { "type": "string", "format": "date" },
        "classId": { "type": "string" },
        "parentName": { "type": "string" },
        "parentPhone": { "type": "string" },
        "address": { "type": "string" }
      },
      "required": ["schoolId", "matricule", "name", "firstName", "classId"]
    },
    "FeeConfig": {
      "title": "Fee Configuration",
      "description": "Types of fees defined by the school",
      "type": "object",
      "properties": {
        "schoolId": { "type": "string" },
        "name": { "type": "string" },
        "amount": { "type": "number" },
        "description": { "type": "string" }
      }
    },
    "Payment": {
      "title": "Payment",
      "description": "Record of a student fee payment",
      "type": "object",
      "properties": {
        "schoolId": { "type": "string" },
        "studentId": { "type": "string" },
        "feeId": { "type": "string" },
        "amount": { "type": "number" },
        "method": { "type": "string", "enum": ["Cash", "Mobile Money", "Bank"] },
        "date": { "type": "string", "format": "date-time" },
        "receiptNumber": { "type": "string" },
        "comptableId": { "type": "string" }
      }
    },
    "Product": {
      "title": "Product",
      "description": "A product listed on the local market",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "string" },
        "category": { "type": "string" },
        "location": { "type": "string" },
        "sellerId": { "type": "string" },
        "imageUrls": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "price", "category", "sellerId"]
    },
    "HousingListing": {
      "title": "Housing Listing",
      "description": "A property listed for rent or sale",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "string" },
        "type": { "type": "string" },
        "location": { "type": "string" },
        "ownerId": { "type": "string" },
        "imageUrls": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "price", "type", "ownerId"]
    },
    "Article": {
      "title": "Article",
      "description": "A well-being or informative article",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "author": { "type": "string" },
        "authorId": { "type": "string" },
        "category": { "type": "string" },
        "content": { "type": "string" },
        "imageUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "author", "authorId", "category", "content"]
    },
    "Course": {
      "title": "Course",
      "description": "A pedagogic course published by a school staff",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "level": { "type": "string" },
        "duration": { "type": "string" },
        "teacher": { "type": "string" },
        "teacherId": { "type": "string" },
        "imageUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "category", "teacherId"]
    }
  },
  "firestore": {
    "/schools/{schoolId}": { "schema": { "$ref": "#/entities/School" }, "description": "School details" },
    "/students/{studentId}": { "schema": { "$ref": "#/entities/Student" }, "description": "Student records" },
    "/feeConfigs/{feeId}": { "schema": { "$ref": "#/entities/FeeConfig" }, "description": "Fee definitions" },
    "/payments/{paymentId}": { "schema": { "$ref": "#/entities/Payment" }, "description": "Payment records" },
    "/products/{productId}": { "schema": { "$ref": "#/entities/Product" }, "description": "Market products" },
    "/housing/{housingId}": { "schema": { "$ref": "#/entities/HousingListing" }, "description": "Real estate listings" },
    "/articles/{articleId}": { "schema": { "$ref": "#/entities/Article" }, "description": "Well-being articles" },
    "/courses/{courseId}": { "schema": { "$ref": "#/entities/Course" }, "description": "Educational courses" },
    "/users/{userId}": { "schema": { "$ref": "#/entities/UserProfile" }, "description": "User profiles" }
  }
}
