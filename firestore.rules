rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Profils utilisateurs
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Écoles
    match /schools/{schoolId} {
      allow read: if true;
      allow write: if request.auth != null; // À restreindre au SuperAdmin plus tard
    }
    
    // Élèves
    match /students/{studentId} {
      allow read, write: if request.auth != null;
    }
    
    // Paiements
    match /payments/{paymentId} {
      allow read, write: if request.auth != null;
    }
    
    // Produits, Logements, Articles, Cours
    match /products/{id} { allow read: if true; allow write: if request.auth != null; }
    match /housing/{id} { allow read: if true; allow write: if request.auth != null; }
    match /articles/{id} { allow read: if true; allow write: if request.auth != null; }
    match /courses/{id} { allow read: if true; allow write: if request.auth != null; }
    
    match /feeConfigs/{id} { allow read: if true; allow write: if request.auth != null; }
  }
}